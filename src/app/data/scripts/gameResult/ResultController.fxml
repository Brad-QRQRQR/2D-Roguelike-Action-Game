<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.data.scripts.gameResult.ResultController">
    <children>
        <ImageView fx:id="backgroundImage" fitHeight="540.0" fitWidth="980.0" pickOnBounds="true" preserveRatio="true" />
        <VBox alignment="CENTER" layoutX="340.0" layoutY="120.0" prefHeight="300.0" prefWidth="300.0" spacing="20.0">
            <children>
                <Label text="遊戲結束" textFill="BLACK">
                    <font>
                        <Font name="Arial Black" size="36.0" />
                    </font>
                </Label>
                <VBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: rgba(0,0,0,0.7); -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <Label fx:id="timeLabel" text="存活時間: " textFill="WHITE">
                            <font>
                                <Font name="Arial" size="18.0" />
                            </font>
                        </Label>
                        <Label fx:id="cardsHeldLabel" text="持有技能: " textFill="WHITE">
                            <font>
                                <Font name="Arial" size="18.0" />
                            </font>
                        </Label>
                        <Label fx:id="cardsUsedLabel" text="已使用技能: " textFill="WHITE">
                            <font>
                                <Font name="Arial" size="18.0" />
                            </font>
                        </Label>
                        <Separator prefWidth="200.0" />
                        <Label fx:id="totalScoreLabel" text="總分: " textFill="#f9e300">
                            <font>
                                <Font name="Arial Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="restartButton" mnemonicParsing="false" onAction="#handleRestart" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="重新" />
                        <Button fx:id="exitButton" mnemonicParsing="false" onAction="#handleExit" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;" text="結束遊戲" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>